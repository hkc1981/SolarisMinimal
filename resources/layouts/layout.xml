<layout id="MainLayout">
    <!-- Title -->
    <label text="SOLARIS MINIMAL" x="center" y="15%" font="Graphics.FONT_XTINY" justification="Graphics.TEXT_JUSTIFY_CENTER" color="Graphics.COLOR_LT_GRAY" />
    
    <!-- Message Label -->
    <label id="MessageLabel" text="Press Select!" x="center" y="45%" font="Graphics.FONT_MEDIUM" justification="Graphics.TEXT_JUSTIFY_CENTER" color="Graphics.COLOR_WHITE" />
    
